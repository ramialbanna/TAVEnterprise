# Copy to .dev.vars for local Worker development only.
# Never commit .dev.vars — it is in .gitignore.
# Keep every secret placeholder in this file as replace_me.
#
# Source of truth for names: src/types/env.ts and wrangler.toml.
# Non-secret flags live in wrangler.toml [vars]; override them here for local dev.

# ── Database ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# ── Ingest authentication ──────────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=replace_me
NORMALIZER_SECRET=replace_me

# ── Cox/Manheim Wholesale-Valuations API ──────────────────────────────────────
# Current account is Cox Bridge 2 / client_credentials.
# See docs/03-api/manheim-cox.md for full details.
MANHEIM_API_VENDOR=cox
MANHEIM_GRANT_TYPE=client_credentials
MANHEIM_SCOPE=wholesale-valuations.vehicle.mmr-ext.get
MANHEIM_CLIENT_ID=replace_me
MANHEIM_CLIENT_SECRET=replace_me
# Required by the Env binding even when using client_credentials; leave replace_me
# locally unless you switch to the legacy password grant.
MANHEIM_USERNAME=replace_me
MANHEIM_PASSWORD=replace_me
# Cox sandbox endpoints. Copy MANHEIM_TOKEN_URL verbatim from the Cox app detail page;
# the path segment after /oauth2/ is per-app and must not be guessed.
MANHEIM_TOKEN_URL=https://authorize.coxautoinc.com/oauth2/REPLACE_AUTH_SERVER_ID/v1/token
# Cox MMR 1.4 base URL — must end in /mmr; code appends /vin/{vin} or /search/{year}/{make}/{model}/{bodyname}
MANHEIM_MMR_URL=https://sandbox.api.coxautoinc.com/wholesale-valuations/vehicle/mmr
# Cox integration:  https://integration.api.coxautoinc.com/wholesale-valuations/vehicle/mmr
# Cox production:   https://api.coxautoinc.com/wholesale-valuations/vehicle/mmr
#
# Legacy Manheim password grant (deprecated — current account is Cox).
# Revert by setting: MANHEIM_API_VENDOR=manheim, MANHEIM_GRANT_TYPE=password,
# then fill MANHEIM_USERNAME / MANHEIM_PASSWORD instead of client_credentials fields.

# ── Alerts ─────────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=replace_me
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=replace_me
ALERT_TO_NUMBER=replace_me

# ── Admin / frontend API ───────────────────────────────────────────────────────
ADMIN_API_SECRET=replace_me
# Bearer token for the /app/* frontend product API. Keep distinct from ADMIN_API_SECRET.
APP_API_SECRET=replace_me

# ── Intelligence worker (when MANHEIM_LOOKUP_MODE=worker) ────────────────────
# Shared secret for worker→intel auth (x-tav-service-secret). Must match
# INTEL_SERVICE_SECRET in workers/tav-intelligence-worker.
INTEL_WORKER_SECRET=replace_me

# ── Apify bridge (when APIFY_WEBHOOK_ENABLED=true) ─────────────────────────────
# Bearer token Apify webhooks present at POST /apify-webhook.
APIFY_WEBHOOK_SECRET=replace_me
# Apify Personal Access Token for dataset/run fetches.
APIFY_TOKEN=replace_me

# ── LLM Y/M/M/S normalization (item 57) ────────────────────────────────────────
# Anthropic API key used by src/llm/anthropicClient.ts to propose Y/M/M/S
# identity at ingest. Absent/placeholder = LLM path is treated as not
# configured regardless of LLM_YMMS_ENABLED (falls back to the offline
# matcher — see resolveListingWithLLM.ts). NEVER commit a real key.
ANTHROPIC_API_KEY=replace_me

# ── Non-secret vars (wrangler.toml [vars]; override here for local) ────────────
# HYBRID_BUYBOX_ENABLED=false
# MANHEIM_LOOKUP_MODE=direct   # "direct" = main worker calls Cox directly (fine for local ingest without intel worker)
#                              # "worker" = MMR via tav-intelligence-worker (staging + production default)
# INTEL_WORKER_URL=            # e.g. https://tav-intelligence-worker-staging.rami-1a9.workers.dev
# APIFY_WEBHOOK_ENABLED=false  # "true" enables POST /apify-webhook locally
# SCRAPER_REVIEW_MODE=false    # "true" shows recent no-MMR scrapes under Scraper review tab (item 55)
# LLM_YMMS_ENABLED=false       # "true" enables the item-57 Claude Y/M/M/S resolver (see docs/LLM-YMMS-Normalization.md)
# LLM_YMMS_MODEL=claude-sonnet-5
