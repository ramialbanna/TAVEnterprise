{
  "name": "tav-aip",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:intelligence": "wrangler dev --config workers/tav-intelligence-worker/wrangler.toml",
    "dev:maxbuy": "wrangler dev --config workers/maxbuy-worker/wrangler.toml",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:intelligence": "wrangler deploy --config workers/tav-intelligence-worker/wrangler.toml",
    "deploy:intelligence:staging": "bash scripts/check-intel-secrets.sh --env staging && wrangler deploy --config workers/tav-intelligence-worker/wrangler.toml --env staging",
    "deploy:intelligence:production": "bash scripts/check-intel-secrets.sh --env production && wrangler deploy --config workers/tav-intelligence-worker/wrangler.toml --env production",
    "check-secrets:intelligence:staging": "bash scripts/check-intel-secrets.sh --env staging",
    "check-secrets:intelligence:production": "bash scripts/check-intel-secrets.sh --env production",
    "deploy:maxbuy": "wrangler deploy --config workers/maxbuy-worker/wrangler.toml",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"workers/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:int": "vitest run --config vitest.int.config.ts",
    "sync:cox-catalog": "node scripts/sync-cox-catalog.mjs",
    "eval:llm-ymms": "node scripts/eval-llm-ymms.mjs",
    "try:llm-ymms-one": "node scripts/eval-llm-ymms.mjs --one",
    "try:apify-llm-one": "node scripts/try-apify-llm-one.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.90.0"
  }
}
