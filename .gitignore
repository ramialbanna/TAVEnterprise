# =============================================================================
# tav-aip .gitignore
# Repo: ramialbanna/TAV-VAIP
# =============================================================================

# --- macOS ------------------------------------------------------------------
.DS_Store
**/.DS_Store

# --- Claude local-only config -----------------------------------------------
.claude/settings.local.json
CLAUDE.local.md

# --- Secrets (NEVER commit) -------------------------------------------------
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example
*.pem
*.key

# --- Node / npm -------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# --- Cloudflare Workers / Wrangler / Miniflare ------------------------------
.wrangler/
**/.wrangler/
.wrangler-out-test/
**/.wrangler-out-test/
.miniflare/
worker-configuration.d.ts

# --- TypeScript / Vite / Vitest build outputs -------------------------------
dist/
build/
out/
coverage/
.vitest-cache/
*.tsbuildinfo

# --- Editor / IDE -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude session memory (local only) ------------------------------------
.claude-memory.md

# --- Logs / scratch ---------------------------------------------------------
*.log
logs/
*.local
*.tmp
tmp/
scratch/
supabase/.temp/

# --- Item 57 eval output (may contain listing text; local-only) -------------
scripts/_eval-results/

# --- Item 56 backfill scratch/data dumps (local-only, not for git history) --
docs/_apify_backfill_listings.json
docs/_apify_backfill_missed.json
docs/_apify_backfill_runs.json
docs/_apify_backfill_sql/
docs/_apify_backfill_progress.jsonl

.vercel
