# Copy to .dev.vars for local development only.
# Never commit .dev.vars — it is in .gitignore.
# Keep every value in this file as replace_me.

# ── Database ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# ── Ingest authentication ──────────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=replace_me
NORMALIZER_SECRET=replace_me

# ── Manheim MMR API ────────────────────────────────────────────────────────────
MANHEIM_CLIENT_ID=replace_me
MANHEIM_CLIENT_SECRET=replace_me
MANHEIM_USERNAME=replace_me
MANHEIM_PASSWORD=replace_me
# Production endpoints:
MANHEIM_TOKEN_URL=https://api.manheim.com/oauth2/token.oauth2
MANHEIM_MMR_URL=https://api.manheim.com/valuations
# UAT/pre-production endpoints (comment out above, uncomment below):
# MANHEIM_TOKEN_URL=https://uat.api.manheim.com/oauth2/token.oauth2
# MANHEIM_MMR_URL=https://uat.api.manheim.com/valuations

# ── Alerts ─────────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=replace_me
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=replace_me
ALERT_TO_NUMBER=replace_me

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_API_SECRET=replace_me

# ── Feature flags (set in wrangler.toml [vars] for prod; override here for local) ──
# HYBRID_BUYBOX_ENABLED=false
