# =============================================================================
# tav-aip .gitignore
# Repo: ramialbanna/TAV-VAIP
# =============================================================================

# --- macOS ------------------------------------------------------------------
.DS_Store
**/.DS_Store

# --- Claude local-only config -----------------------------------------------
.claude/settings.local.json
CLAUDE.local.md

# --- Secrets (NEVER commit) -------------------------------------------------
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example
*.pem
*.key

# --- Node / npm -------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# --- Cloudflare Workers / Wrangler / Miniflare ------------------------------
.wrangler/
**/.wrangler/
.miniflare/
worker-configuration.d.ts

# --- TypeScript / Vite / Vitest build outputs -------------------------------
dist/
build/
out/
coverage/
.vitest-cache/
*.tsbuildinfo

# --- Editor / IDE -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs / scratch ---------------------------------------------------------
*.log
logs/
*.local
*.tmp
tmp/
scratch/
