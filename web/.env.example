# /web environment — ALL of these are SERVER-ONLY.
#
# Local dev:  copy this file to `web/.env.local` (gitignored) and fill in real values.
# Vercel:     set the same keys in the project's Production and Preview env scopes.
#
# NEVER prefix any of these with NEXT_PUBLIC_ and never log them — none may reach the
# browser bundle. The browser only ever talks to /web's own /api/app/* proxy routes,
# which inject APP_API_SECRET server-side; the secret and the Worker URL are never
# exposed to client JavaScript.

# Cloudflare Worker /app/* API — ORIGIN ONLY (the proxy appends "/app"; do NOT include /app here).
#   Production deploy        -> https://tav-aip-production.rami-1a9.workers.dev
#   Preview / local dev      -> https://tav-aip-staging.rami-1a9.workers.dev
#   (local Worker via wrangler dev, optional) -> http://localhost:8787
APP_API_BASE_URL=https://tav-aip-staging.rami-1a9.workers.dev

# Bearer token for /app/* — SERVER-ONLY SECRET. The browser must never see this value.
# Use the staging Worker's APP_API_SECRET for local/preview, the production Worker's for production.
APP_API_SECRET=replace_me

# Auth.js — SERVER-ONLY SECRETS.
#   AUTH_SECRET: session cookie/JWT encryption key. Generate with: openssl rand -base64 32
#   AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: Google OAuth 2.0 client credentials.
AUTH_SECRET=replace_me
AUTH_GOOGLE_ID=replace_me
AUTH_GOOGLE_SECRET=replace_me

# Google Workspace email domain allowed to sign in. Defaults to texasautovalue.com if unset.
ALLOWED_EMAIL_DOMAIN=texasautovalue.com
